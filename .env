# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=yawtai
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Service URLs
API_SERVER_URL=http://localhost:3001
AI_ENGINE_URL=http://localhost:3002
DEBUG_AGENT_URL=http://localhost:3003
PROJECT_GENERATOR_URL=http://localhost:3004
REPO_ANALYSIS_URL=http://localhost:3005

# Frontend Configuration (Vite/React)
VITE_API_URL=http://localhost:3001
VITE_AI_ENGINE_URL=http://localhost:3002

# Cloudflare Pages Configuration
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_PROJECT_NAME=ai-development-assistant
VITE_CLOUDFLARE_PROJECT_ID=your-cloudflare-project-id
VITE_CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# Application Configuration
NODE_ENV=development
PORT=3001

# File Upload Configuration
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
